# Which chain the wallet app talks to. No default — an unset or unrecognized
# value throws at startup rather than silently falling back to mainnet.
# Known values: base-mainnet, base-sepolia
#
# base-sepolia is the safe local-dev default: it's a testnet, so mistakes
# here don't move real funds.
NEXT_PUBLIC_NOISEBOUND_NETWORK=base-sepolia