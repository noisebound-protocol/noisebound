{
  "name": "@noisebound/x402-pqc",
  "version": "0.0.0",
  "private": true,
  "description": "x402 HTTP payment protocol adapted to Noisebound's PQC session-capability model",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
