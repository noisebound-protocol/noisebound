{
  "name": "@noisebound/model-eval",
  "version": "0.0.0",
  "private": true,
  "description": "Standalone evaluation harness for locally-served open-weight models against σ-1's real tool-calling interface. Dev/research tool only — never imported by apps/app or other packages.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "eval": "tsc -p tsconfig.json && node dist/cli.js"
  },
  "dependencies": {
    "@noisebound/sigma-core": "workspace:*",
    "@noisebound/sigma-execute": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
