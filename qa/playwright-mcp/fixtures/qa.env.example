# Copy to qa/playwright-mcp/.qa.local.env (gitignored) and fill in the funder key,
# or export these directly before running scripts/start-dev-server.*
#
# Base Sepolia only — this harness never targets base-mainnet.
NEXT_PUBLIC_NOISEBOUND_NETWORK=base-sepolia

# Hardhat's well-known account #0 test key (public, intentionally unfunded on
# real networks — see apps/app/lib/fixtures/devWallet.ts). Session-key issuance
# will submit a real funding tx to Base Sepolia using this key; if it has no
# testnet ETH, the UI will legitimately show a funding-error state instead of
# "Issued and funded" — see specs/01-wallet-import.md for how to handle both.
NOISEBOUND_DEV_FUNDER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Points the app's recipient-history store at an isolated, disposable copy of
# fixtures/recipient-history.seed.json instead of the repo's real .data/ dir.
# scripts/start-dev-server.* sets this for you to a scratch path automatically.
NOISEBOUND_RECIPIENT_HISTORY_PATH=./qa/playwright-mcp/.scratch/recipient-history.json
